<div class="max-w-2xl mx-auto">
  <div class="bg-white overflow-hidden shadow rounded-lg">
    <div class="px-6 py-4 border-b border-gray-200">
      <h1 class="text-xl sm:text-2xl font-bold text-gray-900">Setup Password</h1>
      <p class="mt-1 text-sm text-gray-500">
        Set password baru untuk akun <span class="font-medium text-gray-700"><%= @user.name %></span>.
      </p>
    </div>

    <div class="p-6">
      <%= form_with model: @user, url: setup_password_user_path(@user), method: :patch, local: true, html: { class: "space-y-6" } do |f| %>
        <% if @user.errors.any? %>
          <div class="bg-red-50 border-l-4 border-red-400 p-4">
            <div class="text-sm text-red-700">
              <p class="font-medium">Password belum bisa disimpan:</p>
              <ul class="list-disc pl-5 mt-2 space-y-1">
                <% @user.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        <% end %>

        <div>
          <%= f.label :password, "Password Baru", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.password_field :password,
                               autocomplete: "new-password",
                               class: "w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
                               placeholder: "Masukkan password baru" %>
          <p class="mt-1 text-xs text-gray-500">
            Minimal 8 karakter, wajib berisi huruf dan angka.
          </p>
        </div>

        <div>
          <%= f.label :password_confirmation, "Konfirmasi Password", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.password_field :password_confirmation,
                               autocomplete: "new-password",
                               class: "w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
                               placeholder: "Ulangi password baru" %>
        </div>

        <div class="flex flex-col sm:flex-row gap-3 pt-6 border-t border-gray-200">
          <%= f.submit "Simpan Password",
                       class: "inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
          <%= link_to "Batal",
                      users_path,
                      class: "inline-flex items-center justify-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
